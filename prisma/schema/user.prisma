enum Role {
    TENANT
    LANDLORD
    ADMIN
}

enum UserStatus {
    ACTIVE
    BANNED
}

model User {
    id       String     @id @default(uuid())
    name     String     @db.VarChar(20)
    email    String     @unique
    password String
    phone    String?
    status   UserStatus @default(ACTIVE)
    role     Role       @default(TENANT)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
